{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product for sale in the e-commerce store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "shortDescription": { "type": "string", "description": "Short summary" },
        "fullDescription": { "type": "string", "description": "Detailed description" },
        "sku": { "type": "string", "description": "Stock Keeping Unit" },
        "category": { "type": "string", "description": "Main category" },
        "subcategory": { "type": "string", "description": "Sub-category" },
        "brand": { "type": "string", "description": "Product brand" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Search tags" },
        "regularPrice": { "type": "number", "description": "Standard price" },
        "salePrice": { "type": "number", "description": "Discounted price" },
        "discountPercentage": { "type": "number", "description": "Calculated discount" },
        "quantity": { "type": "number", "description": "Stock count" },
        "stockStatus": { "type": "string", "enum": ["In Stock", "Out of Stock", "Low Stock"], "description": "Current availability" },
        "lowStockAlert": { "type": "number", "description": "Alert threshold" },
        "mainImage": { "type": "string", "description": "Primary product image URL" },
        "galleryImages": { "type": "array", "items": { "type": "string" }, "description": "Additional image URLs" },
        "thumbnailImage": { "type": "string", "description": "Small preview image URL" },
        "colors": { "type": "array", "items": { "type": "string" }, "description": "Available colors" },
        "sizes": { "type": "array", "items": { "type": "string" }, "description": "Available sizes" },
        "material": { "type": "string", "description": "Product material" },
        "model": { "type": "string", "description": "Product model" },
        "weight": { "type": "string", "description": "Shipping weight" },
        "dimensions": { "type": "string", "description": "Package dimensions" },
        "deliveryDays": { "type": "number", "description": "Estimated delivery time" },
        "status": { "type": "string", "enum": ["Active", "Draft", "Featured"], "description": "Publishing status" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "regularPrice", "quantity", "status"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" },
        "productCount": { "type": "number" }
      },
      "required": ["name", "slug"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Homepage slider or promotional banner",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "type": { "type": "string", "enum": ["Home Slider", "Flash Sale", "Promo"] },
        "active": { "type": "boolean" }
      },
      "required": ["title", "image", "type"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase record",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "paymentMethod": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "items", "total", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Store categories"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Store banners"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Store orders"
    }
  }
}
