rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == "umairmayo607@gmail.com" ||
        request.auth.token.email == "carenexon143@gmail.com"
      );
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.category is string &&
             data.regularPrice is number && data.regularPrice >= 0 &&
             data.quantity is number && data.quantity >= 0 &&
             data.status in ['Active', 'Draft', 'Featured'];
    }

    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.slug is string && data.slug.size() > 0;
    }

    function isValidBanner(data) {
      return data.title is string && data.title.size() > 0 &&
             data.image is string &&
             data.type in ['Home Slider', 'Flash Sale', 'Promo'];
    }

    function isValidOrder(data) {
      return data.customerId is string &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Products: Publicly readable, admin writable
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProduct(request.resource.data);
    }

    // Categories: Publicly readable, admin writable
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidCategory(request.resource.data);
    }

    // Banners: Publicly readable, admin writable
    match /banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidBanner(request.resource.data);
    }

    // Orders: Owner readable, admin readable/writable
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.customerId) || isAdmin());
      allow create: if isAuthenticated() && (isOwner(request.resource.data.customerId) || isAdmin()) && isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    // Users: Owner readable/writable, admin readable
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
