# .env.example
# Application URLs provided by the platform (required for callback URL construction if dynamic construction fails)
APP_URL=
SHARED_APP_URL=

# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database Configuration
MONGO_URI= # Required: Remote MongoDB URI (e.g. MongoDB Atlas). Localhost will not work.

# Session Configuration
SESSION_SECRET=
NODE_ENV=development
